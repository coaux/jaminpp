	  f=`echo "$$p" | sed 's,^.*/,,;s/$(EXEEXT)$$//;$(transform);s/$$/$(EXEEXT)/'`; \
	  echo " rm -f $(DESTDIR)$(pkgbindir)/$$f"; \
	  rm -f $(DESTDIR)$(pkgbindir)/$$f; \
	done

